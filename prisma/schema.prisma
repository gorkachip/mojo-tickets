generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  sales
}

enum TicketCategory {
  ai_response
  app_bug
  idea
}

enum TicketStatus {
  pending
  approved
  implemented
  rejected
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String
  role      Role     @default(sales)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Ticket {
  id                  String          @id @default(uuid())
  category            TicketCategory
  status              TicketStatus    @default(pending)
  name                String
  email               String
  description         String
  expectedResponse    String?         @map("expected_response")
  leadContact         String?         @map("lead_contact")
  screenshotUrl       String?         @map("screenshot_url")
  approvedBy          String?         @map("approved_by")
  approvedComment     String?         @map("approved_comment")
  approvedAt          DateTime?       @map("approved_at")
  implementedBy       String?         @map("implemented_by")
  implementedComment  String?         @map("implemented_comment")
  implementedAt       DateTime?       @map("implemented_at")
  rejectedBy          String?         @map("rejected_by")
  rejectedComment     String?         @map("rejected_comment")
  rejectedAt          DateTime?       @map("rejected_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  actions             TicketAction[]

  @@map("tickets")
}

model TicketAction {
  id        String           @id @default(uuid())
  ticketId  String           @map("ticket_id")
  action    String
  userName  String           @map("user_name")
  comment   String?
  createdAt DateTime         @default(now()) @map("created_at")
  ticket    Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  mentions  TicketMention[]

  @@index([ticketId, createdAt])
  @@map("ticket_actions")
}

model TicketMention {
  id                String       @id @default(uuid())
  actionId          String       @map("action_id")
  ticketId          String       @map("ticket_id")
  mentionedUsername String       @map("mentioned_username")
  readAt            DateTime?    @map("read_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  action            TicketAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([mentionedUsername, readAt, createdAt])
  @@index([ticketId])
  @@map("ticket_mentions")
}

model Upload {
  id        String   @id @default(uuid())
  filename  String
  mimetype  String
  data      Bytes
  createdAt DateTime @default(now()) @map("created_at")

  @@map("uploads")
}
